/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'STAR_GENOMEGENERATE_HUMAN' {
        ext.args = '--genomeSAindexNbases 14'
        publishDir = [
            path: { "${params.outdir}/star_human" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'STAR_GENOMEGENERATE_VIRUS' {
       ext.args = '--genomeSAindexNbases 12'
       publishDir = [
            path: { "${params.outdir}/star_virus" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'FASTP' {
        ext.args = '--length_required 40 --trim_poly_x'
    }

    withName: 'STAR_ALIGN_HUMAN' {
        ext.args = '--readFilesCommand zcat --outSAMunmapped Within --outSAMtype BAM SortedByCoordinate'
        publishDir = [
            path: { "${params.outdir}/star_human" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SAMTOOLS_VIEW' {
        ext.args = "-f 4 -e '[uT] != 3' -b"
    }

    withName: 'BAMFILTERPOLYX' {
        ext.prefix = { "${meta.id}.filtered" }
    }

    withName: 'KZFILTER' {
        ext.prefix = { "${input_fq.simpleName}.kz" }
        ext.args = '--threshold 0.1'
    }

    withName: 'STAR_ALIGN_VIRUS' {
        ext.args = '--readFilesCommand zcat --outSAMtype BAM SortedByCoordinate'
        publishDir = [
            path: { "${params.outdir}/star_virus" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MKSUMMARYVIRUSCOUNT' {
        ext.prefix = { "VIRTUS.output-${meta.id}" }
    }

}
